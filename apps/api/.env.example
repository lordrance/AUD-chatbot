# 本地 API / Alembic（与仓库根目录 docker-compose db 一致时可用 127.0.0.1）
DATABASE_URL=postgresql+psycopg://safechat:safechat@127.0.0.1:5432/safechat_aud
# 集成测试：若设置，pytest 会将其用作应用连接串（见 tests/conftest.py）；可与 DATABASE_URL 相同
# TEST_DATABASE_URL=postgresql+psycopg://safechat:safechat@127.0.0.1:5432/safechat_aud
# 可选：覆盖默认同意书版本（默认见 app/constants.py）
# CONSENT_DOCUMENT_VERSION=2026-04-04-v1
# 可选：提示词包版本号（须与 prompts/manifest.yaml 中 bundles 键一致）
# PROMPT_BUNDLE_VERSION=0.1
# LLM（可选；未配置对应 provider 的密钥则聊天为 stub）
# 读取：app/config.py；在 apps/api 下启动 API / 跑 eval 时加载本目录 .env
#
# --- LLM_PROVIDER=openai（默认）或 gemini ---
#
# OpenAI：
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
#
# Gemini（Google AI Studio；OpenAI 兼容端点 https://ai.google.dev/gemini-api/docs/openai ）：
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=<仅本机 .env，勿提交 Git>
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_MODEL=gemini-2.0-flash
#
# 兼容旧用法：Gemini Key 仍可放在 OPENAI_API_KEY + OPENAI_BASE_URL（保持 LLM_PROVIDER=openai）。
# json_schema strict 若不兼容会回退 stub，可换 GEMINI_MODEL。
#
# LLM_TIMEOUT_SECONDS=45
# LLM_MAX_RETRIES=2
