# SafeChat-AUD — 本地 pilot-v1 PostgreSQL 验收环境
# =============================================================================
# 位置：仓库根目录（与 docker-compose.yml 同级）
#
# 首次使用（推荐）：复制本文件为同目录下的 .env.acceptance
#   PowerShell（仓库根目录）：
#     Copy-Item -Path .env.acceptance.example -Destination .env.acceptance
#   验收脚本会优先读取 .env.acceptance；若不存在则使用本示例文件。
#
# 下列值必须与 docker-compose.yml 中 services.db 一致（POSTGRES_* 与端口映射）。
# 仅供本机开发/验收，非生产密钥。
# =============================================================================

DATABASE_URL=postgresql+psycopg://safechat:safechat@127.0.0.1:5432/safechat_aud

# 与 DATABASE_URL 指向同一库；pytest 会将 TEST_DATABASE_URL 同步到进程内 DATABASE_URL（见 apps/api/tests/conftest.py）
TEST_DATABASE_URL=postgresql+psycopg://safechat:safechat@127.0.0.1:5432/safechat_aud
